{
  "name": "revaulter-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:fonts && npm run build:js && tailwindcss -i ./assets/css/main.css -o ./static/css/main.css --minify",
    "build:fonts": "mkdir -p ./static/fonts/geist && cp ./node_modules/geist/dist/fonts/geist-sans/Geist-Variable.woff2 ./static/fonts/geist/Geist-Variable.woff2 && cp ./node_modules/geist/dist/fonts/geist-mono/GeistMono-Variable.woff2 ./static/fonts/geist/GeistMono-Variable.woff2",
    "build:js": "esbuild ./assets/js/mermaid-init.js --bundle --format=esm --target=es2022 --minify --outfile=./static/js/mermaid-init.js",
    "watch": "tailwindcss -i ./assets/css/main.css -o ./static/css/main.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@types/node": "24.12.2",
    "esbuild": "0.28.0",
    "tailwindcss": "4.2.4"
  },
  "dependencies": {
    "geist": "1.7.0",
    "mermaid": "11.12.0",
    "@vercel/functions": "3.4.4"
  }
}
