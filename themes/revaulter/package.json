{
  "name": "revaulter-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:js && tailwindcss -i ./assets/css/main.css -o ./static/css/main.css --minify",
    "build:js": "esbuild ./assets/js/mermaid-init.js --bundle --format=esm --target=es2022 --minify --outfile=./static/js/mermaid-init.js",
    "watch": "tailwindcss -i ./assets/css/main.css -o ./static/css/main.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "esbuild": "0.28.0",
    "tailwindcss": "4.2.4"
  },
  "dependencies": {
    "mermaid": "11.12.0"
  }
}
