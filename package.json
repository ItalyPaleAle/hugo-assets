{
  "name": "revaulter-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run theme:build && HUGO_CACHEDIR=$PWD/.hugo_cache PATH=$PWD/themes/revaulter/node_modules/.bin:$PATH hugo server",
    "build": "npm run theme:build && HUGO_CACHEDIR=$PWD/.hugo_cache PATH=$PWD/themes/revaulter/node_modules/.bin:$PATH hugo --gc --minify --cleanDestinationDir",
    "theme:build": "npm --prefix themes/revaulter run build",
    "theme:install": "npm --prefix themes/revaulter install"
  }
}
